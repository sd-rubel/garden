{% set solution = gardening_solutions[0] %}
<article class="post-premium">
    <div class="post-hero" {% if solution.seo.og_image %}style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('{{ solution.seo.og_image }}');"{% endif %}>
        <div class="hero-content">
            <h1>{{ solution.title }}</h1>
            <p class="hero-desc">{{ solution.short_description }}</p>
        </div>
    </div>

    <div class="post-body">
        <div class="post-meta-grid">
            <span><i class="fas fa-hourglass-half"></i> প্রস্তুতিকাল: {{ solution.preparation_time_hours }} ঘণ্টা</span>
            <span><i class="fas fa-calendar-week"></i> প্রয়োগ间隔: {{ solution.application_interval_days }} দিন</span>
            <span><i class="fas fa-box"></i> সংরক্ষণ: {{ solution.shelf_life_days }} দিন</span>
            <span><i class="fas fa-seedling"></i> ক্যাটেগরি: {{ solution.category | replace("_", " ") | title }}</span>
        </div>

        <div class="long-description">
            <h2><i class="fas fa-info-circle"></i> বিস্তারিত বর্ণনা</h2>
            <p>{{ solution.long_description }}</p>
        </div>

        <!-- উপকরণ সারণি -->
        <div class="ingredients-card">
            <h2><i class="fas fa-list-ul"></i> উপকরণ ও পরিমাণ</h2>
            <div class="ingredients-grid">
                {% for ing in solution.ingredients_summary_table %}
                <div class="ing-item">
                    <span class="ing-emoji">{{ ing.emoji }}</span>
                    <span class="ing-name">{{ ing.item }}</span>
                    <span class="ing-amount">{{ ing.amount }}</span>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- প্রস্তুত প্রণালী -->
        <div class="process-timeline">
            <h2><i class="fas fa-tasks"></i> তৈরির ধাপ</h2>
            <div class="steps">
                {% for step in solution.working_process %}
                <div class="step">
                    <div class="step-number">{{ step.step }}</div>
                    <div class="step-desc">{{ step.description }}</div>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- FAQs -->
        <div class="faq-section">
            <h2><i class="fas fa-question-circle"></i> সাধারণ জিজ্ঞাসা</h2>
            <div class="accordion">
                {% for faq in solution.faqs %}
                <div class="accordion-item">
                    <button class="accordion-btn">{{ faq.question }} <i class="fas fa-chevron-down"></i></button>
                    <div class="accordion-content">{{ faq.answer }}</div>
                </div>
                {% endfor %}
            </div>
        </div>

        <div class="share-premium">
            <button id="shareBtn" class="share-premium-btn"><i class="fas fa-share-alt"></i> শেয়ার করুন</button>
        </div>
    </div>
</article>

<script>
    // Accordion functionality
    document.querySelectorAll('.accordion-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const content = btn.nextElementSibling;
            content.style.display = content.style.display === 'block' ? 'none' : 'block';
            btn.classList.toggle('active');
        });
    });
    // Share
    const shareBtn = document.getElementById('shareBtn');
    if(shareBtn && navigator.share) {
        shareBtn.addEventListener('click', () => navigator.share({title: document.title, text: '{{ solution.short_description }}', url: window.location.href}));
    } else if(shareBtn) shareBtn.style.display = 'none';
</script>